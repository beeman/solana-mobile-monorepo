# Optional during Expo development. If unset, apps/native derives the host
# from Expo and uses port 3000 automatically.
# Optional in development. Defaults to devnet when unset.
# EXPO_PUBLIC_SOLANA_AUTH_CLUSTER=devnet
# Optional in development. Defaults to the devnet RPC URL when unset.
# EXPO_PUBLIC_SOLANA_CLUSTER_URL=https://api.devnet.solana.com
# If the printed "Native server URL" is wrong for your network or device,
# uncomment this and set your host machine's LAN IP manually.
# EXPO_PUBLIC_SERVER_URL=http://192.168.1.100:3000
# REACT_NATIVE_PACKAGER_HOSTNAME=
