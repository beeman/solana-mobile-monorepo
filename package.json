{
  "dependencies": {
    "@solana-mobile-monorepo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@solana-mobile-monorepo/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "turbo": "^2.9.4",
    "typescript": "catalog:"
  },
  "name": "solana-mobile-monorepo",
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:local": "bun run --cwd packages/db db:local",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio",
    "dev:native": "bun run --cwd apps/native android",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:web": "bun run --cwd apps/web dev",
    "docker:build:server": "docker build -f Dockerfile.server -t ghcr.io/beeman/solana-mobile-monorepo-server .",
    "docker:build:web": "docker build -f Dockerfile.web -t ghcr.io/beeman/solana-mobile-monorepo-web .",
    "docker:push:server": "docker push ghcr.io/beeman/solana-mobile-monorepo-server",
    "docker:push:web": "docker push ghcr.io/beeman/solana-mobile-monorepo-web",
    "docker:run:server": "docker run --rm --name solana-mobile-monorepo-server --init --stop-signal=SIGINT -it --env-file apps/server/.env -p 3000:3000 ghcr.io/beeman/solana-mobile-monorepo-server",
    "docker:run:web": "docker run --rm --name solana-mobile-monorepo-web --init --stop-signal=SIGINT -it -p 3001:3001 ghcr.io/beeman/solana-mobile-monorepo-web",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "rename": "bun scripts/rename.ts",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "setup": "bun run scripts/copy-env.ts",
    "start:web": "bun run --cwd apps/web start",
    "test": "turbo test"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts",
      "turbo/generators"
    ],
    "catalog": {
      "@ai-sdk/react": "^3.0.3",
      "@better-auth/expo": "^1.5.6",
      "@libsql/client": "0.15.15",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/server": "^1.12.2",
      "@orpc/tanstack-query": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "@solana/kit": "^6.0.0",
      "@solana/kit-plugin-rpc": "^0.2.0",
      "@types/bun": "^1.3.11",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "ai": "^6.0.3",
      "better-auth": "^1.5.6",
      "better-auth-solana": "1.0.0-canary-20260330165420",
      "dotenv": "^17.2.2",
      "drizzle-orm": "^0.45.1",
      "hono": "^4.8.2",
      "libsql": "0.5.22",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "typescript": "^5.9.3",
      "zod": "^4.1.13"
    }
  },
  "create-seed": {
    "instructions": [
      "Set up the local database:",
      "+{pm} run db:local",
      "Apply the schema once:",
      "+{pm} run db:push",
      "~",
      "Your database is ready. Start the server:",
      "+{pm} run dev:server",
      "Start the Android app:",
      "+{pm} run dev:native",
      "Start the web app:",
      "+{pm} run dev:web"
    ]
  }
}
